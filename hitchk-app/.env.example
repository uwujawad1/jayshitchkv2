# App
NODE_ENV=development
PORT=5000
SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_PIN=
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.ychnrntppebudsvctpul.supabase.co:5432/postgres
ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-domain.vercel.app
JSON_DB_BOOTSTRAP_MODE=empty
PGSSLMODE=require

# Frontend
VITE_API_URL=https://your-railway-backend.up.railway.app
VITE_ADMIN_TELEGRAM_USERNAME=JayHitsAdmin

# Railway FastAPI wrapper
LEGACY_EXPRESS_PORT=5010

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
TELEGRAM_GROUP_ID=
TELEGRAM_CHANNEL_ID=
TELEGRAM_GROUP_LINK=
TELEGRAM_CHANNEL_LINK=
LOGS_GROUP_ID=
ADMIN_TELEGRAM_USERNAME=@JayHitsAdmin

# Runtime toggles
HITTER_SITE_VISIBLE=true
MAINTENANCE_MODE=false

# Captcha providers
NOPECHA_API_KEY=
CAPTCHAAI_API_KEY=
TWOCAPTCHA_API_KEY=
CAPSOLVER_API_KEY=

# Stripe charge gateway
CHARGE_SK=
CHARGE_AMOUNT=50

# Local testing
# Supabase direct `db.<project-ref>.supabase.co:5432` connections require IPv6 support.
# If your local network is IPv4-only, use the Supabase Session pooler connection string instead.
# Use `.env.local` for your machine-specific local values.
# For Vite, `.env.local` is picked up automatically.
# For the backend in this project, `.env.local` overrides `.env`.
